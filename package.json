{
  "name": "gql-painkiller-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Apollo Server + Prisma demo with deliberately N+1-shaped resolvers, for use with GraphQL Painkiller",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma db push && tsx prisma/seed.ts",
    "generate": "prisma generate"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@prisma/client": "^5.20.0",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^20.16.0"
  }
}
